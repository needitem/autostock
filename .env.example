# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"

# AI runtime (no API key required; uses `codex login`)
AI_PROVIDER="codex-cli"
AI_MODEL="gpt-5.2"
CODEX_BIN="codex"

# Bot message style: compact | standard | detail
BOT_MESSAGE_STYLE="compact"

# Optional: eager-load full universe/categories at import time
# CONFIG_EAGER_LOAD="false"

# Korea Investment & Securities (auto-trading)
KIS_APP_KEY="your_kis_app_key"
KIS_APP_SECRET="your_kis_app_secret"
KIS_ACCOUNT_NO="your_account_number"
KIS_ACCOUNT_PROD="01"
KIS_IS_PAPER="true"

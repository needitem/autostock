# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"

# Local Telegram trade-analysis cache
# TELEGRAM_ANALYSIS_CACHE_MINUTES="15"
# TELEGRAM_NEWS_ANALYSIS_MAX_SYMBOLS="120"
# TELEGRAM_SCAN_WORKERS="12"
# TELEGRAM_NEWS_WORKERS="8"
# TELEGRAM_NEWS_DISCOVERY_MAX_SYMBOLS="0"  # 0 = full all_us universe
# TELEGRAM_CODEX_BATCH_SIZE="12"
# TELEGRAM_FINAL_SYNTHESIS_MAX_SYMBOLS="240"
# TELEGRAM_JOURNAL_HORIZON_DAYS="10"
# TELEGRAM_AUTO_COLLECT_ENABLED="true"
# TELEGRAM_AUTO_COLLECT_INTERVAL_MINUTES="360"
# TELEGRAM_AUTO_NOTIFY_ENABLED="true"
# TELEGRAM_STARTUP_MENU_PUSH_ENABLED="true"

# AI runtime (no API key required; uses `codex login`)
AI_PROVIDER="codex-cli"
AI_MODEL="gpt-5.5"
CODEX_BIN="codex"
# Optional: low | medium | high | xhigh
AI_REASONING_EFFORT="xhigh"
# Heuristic fallback is disabled for local Telegram trade analysis.

# Bot message style: beginner | standard | detail
# (compact is kept as a legacy alias for beginner)
BOT_MESSAGE_STYLE="beginner"

# Optional: eager-load full universe/categories at import time
# CONFIG_EAGER_LOAD="false"

# Optional benchmark path
# AI_BENCHMARK_SYMBOL="QQQ"
# AI_MARKET_INDICATOR="QQQ"

# Korea Investment & Securities (auto-trading)
KIS_APP_KEY="your_kis_app_key"
KIS_APP_SECRET="your_kis_app_secret"
KIS_ACCOUNT_NO="your_account_number"
KIS_ACCOUNT_PROD="01"
KIS_IS_PAPER="true"

# Optional data APIs for deep research pipeline
BOK_ECOS_API_KEY=""
OPENDART_API_KEY=""

# Optional SEC access (required for 13F dataset fetch)
SEC_USER_AGENT="your_name your_email@example.com"

# Optional US rebalance execution safety controls
# AI_ENABLE_EXECUTION_RISK_CAP="true"
# AI_POSITION_RISK_BUDGET_PCT="0.5"          # max portfolio loss per symbol at stop
# AI_ENTRY_MAX_SUPPORT_DISTANCE_ATR="2.0"    # activate ladder only when support is not too far

# Optional inventory beta mode
# INVENTORY_MODE_ENABLED="true"
# INVENTORY_REPORT_TIME="00:20"
# INVENTORY_MOVEMENTS_JSON="data/inventory/movements.json"
# INVENTORY_POLICY_JSON="data/inventory/reorder_policy.json"
# INVENTORY_CHANNEL_SNAPSHOT_JSON="data/inventory/channel_snapshot.json"
# INVENTORY_MISMATCH_THRESHOLD="0.0001"

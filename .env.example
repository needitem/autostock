# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"

# Telegram scheduler (all times in BOT_TIMEZONE)
# BOT_TIMEZONE="Asia/Seoul"
# US_REPORT_TIME="00:00"          # daily report
# US_REBALANCE_TIME="00:10"       # weekly rebalance
# US_REBALANCE_WEEKDAY="0"        # 0=Mon ... 6=Sun

# AI runtime (no API key required; uses `codex login`)
AI_PROVIDER="codex-cli"
AI_MODEL="gpt-5.2"
CODEX_BIN="codex"
# Optional: low | medium | high
# AI_REASONING_EFFORT="medium"

# Bot message style: beginner | standard | detail
# (compact is kept as a legacy alias for beginner)
BOT_MESSAGE_STYLE="beginner"

# Optional: eager-load full universe/categories at import time
# CONFIG_EAGER_LOAD="false"

# Korea Investment & Securities (auto-trading)
KIS_APP_KEY="your_kis_app_key"
KIS_APP_SECRET="your_kis_app_secret"
KIS_ACCOUNT_NO="your_account_number"
KIS_ACCOUNT_PROD="01"
KIS_IS_PAPER="true"

# Optional data APIs for deep research pipeline
BOK_ECOS_API_KEY=""
OPENDART_API_KEY=""

# Optional SEC access (required for 13F dataset fetch)
SEC_USER_AGENT="your_name your_email@example.com"
